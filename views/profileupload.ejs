<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>SocialHub • Update Profile</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter,sans-serif;
}

body{
    min-height:100vh;
    background:#08090B;
    color:white;
    overflow-x:hidden;
    position:relative;
}

/* background lighting */

body::before{
    content:'';
    position:fixed;
    width:500px;
    height:500px;
    left:-150px;
    top:150px;
    background:#7c3aed;
    filter:blur(180px);
    opacity:.22;
    z-index:-2;
}

body::after{
    content:'';
    position:fixed;
    width:450px;
    height:450px;
    right:-100px;
    bottom:100px;
    background:#2563eb;
    filter:blur(180px);
    opacity:.18;
    z-index:-2;
}

/* navbar */

nav{
    height:80px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 50px;
    border-bottom:1px solid rgba(255,255,255,.05);
    backdrop-filter:blur(20px);
}

.logo{
    font-size:36px;
    font-weight:800;
}

.logo span{
    color:#7c3aed;
}

.back-btn{
    padding:14px 24px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.03);
    color:white;
    text-decoration:none;
    transition:.3s;
}

.back-btn:hover{
    transform:translateY(-2px);
}

/* container */

.wrapper{
    max-width:900px;
    margin:50px auto;
    padding:0 20px;
}

/* glass card */

.card{
    background:
    linear-gradient(
    135deg,
    rgba(255,255,255,.05),
    rgba(255,255,255,.02)
    );

    backdrop-filter:blur(25px);

    border:1px solid rgba(255,255,255,.08);

    border-radius:30px;

    padding:45px;

    box-shadow:
    0 30px 100px rgba(0,0,0,.6),
    inset 0 1px 0 rgba(255,255,255,.08);
}

/* heading */

.heading{
    display:flex;
    gap:20px;
    align-items:center;
    margin-bottom:40px;
}

.heading-icon{
    width:70px;
    height:70px;
    border-radius:20px;
    background:linear-gradient(135deg,#7c3aed,#2563eb);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:28px;
}

.heading h1{
    font-size:42px;
    font-weight:800;
}

.heading p{
    color:#9ca3af;
    margin-top:5px;
}

/* profile preview */

.avatar-preview{
    width:170px;
    height:170px;
    margin:0 auto 40px;
    border-radius:50%;
    padding:4px;
    background:linear-gradient(135deg,#7c3aed,#2563eb);
}

.avatar-preview img{
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:50%;
    background:#111827;
}

/* upload area */

.upload-area{
    border:2px dashed rgba(124,58,237,.6);
    border-radius:24px;
    padding:60px;
    text-align:center;
    background:rgba(255,255,255,.02);
    transition:.3s;
}

.upload-area:hover{
    border-color:#7c3aed;
    background:rgba(255,255,255,.04);
}

.upload-icon{
    font-size:80px;
    margin-bottom:20px;
    color:#7c3aed;
}

.upload-title{
    font-size:32px;
    font-weight:700;
    margin-bottom:10px;
}

.upload-sub{
    color:#9ca3af;
    margin-bottom:25px;
}

input[type=file]{
    display:none;
}

.upload-btn{
    background:
    linear-gradient(
    135deg,
    #2563eb,
    #7c3aed
    );

    padding:16px 35px;

    border:none;

    border-radius:15px;

    color:white;

    font-size:16px;

    font-weight:700;

    cursor:pointer;
}

.preview-box{
    margin-top:30px;
    display:none;
}

.preview-box.show{
    display:block;
}

.preview-box img{
    width:250px;
    border-radius:20px;
}

/* buttons */

.actions{
    display:flex;
    gap:20px;
    margin-top:40px;
}

.cancel{
    flex:1;
    padding:18px;
    border-radius:16px;
    border:1px solid rgba(255,255,255,.08);
    background:transparent;
    color:white;
    text-decoration:none;
    text-align:center;
}

.submit{
    flex:2;
    border:none;
    border-radius:16px;
    background:
    linear-gradient(
    135deg,
    #2563eb,
    #7c3aed
    );

    color:white;
    font-size:18px;
    font-weight:700;
    cursor:pointer;
}

/* guidelines */

.guidelines{
    margin-top:50px;
    padding-top:30px;
    border-top:1px solid rgba(255,255,255,.08);
}

.guidelines h3{
    font-size:24px;
    margin-bottom:20px;
}

.guidelines li{
    color:#9ca3af;
    margin-bottom:15px;
    list-style:none;
}

.guidelines i{
    color:#10b981;
    margin-right:10px;
}

/* mobile */

@media(max-width:768px){

nav{
    padding:20px;
}

.heading{
    flex-direction:column;
    text-align:center;
}

.heading h1{
    font-size:32px;
}

.upload-area{
    padding:40px 20px;
}

.actions{
    flex-direction:column;
}

}

</style>
</head>

<body>

<nav>
    <div class="logo">
        Social<span>Hub</span>
    </div>

    <a href="/profile" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i>
        Back
    </a>
</nav>

<div class="wrapper">

<div class="card">

<div class="heading">
    <div class="heading-icon">
        <i class="fa-solid fa-image"></i>
    </div>

    <div>
        <h1>Update Profile Picture</h1>
        <p>Choose a new photo to personalize your profile.</p>
    </div>
</div>

<div class="avatar-preview">
    <img
        id="avatarPreview"
        src="/images/default.jpg">
</div>

<form action="/upload"
      method="post"
      enctype="multipart/form-data">

<div class="upload-area">

<div class="upload-icon">
<i class="fa-solid fa-cloud-arrow-up"></i>
</div>

<div class="upload-title">
Drag & Drop Your Image
</div>

<div class="upload-sub">
JPG • PNG • GIF • Maximum 5MB
</div>

<label class="upload-btn">
Choose File
<input
type="file"
name="image"
accept="image/*"
required
onchange="previewImage(event)">
</label>

<div
id="previewContainer"
class="preview-box">

<img id="previewImage">

</div>

</div>

<div class="actions">

<a href="/profile"
class="cancel">
Cancel
</a>

<button
type="submit"
class="submit">
<i class="fa-solid fa-upload"></i>
Upload Photo
</button>

</div>

</form>

<div class="guidelines">

<h3>
Guidelines for Best Results
</h3>

<ul>
<li><i class="fa-solid fa-circle-check"></i>Use good lighting</li>
<li><i class="fa-solid fa-circle-check"></i>Use high quality images</li>
<li><i class="fa-solid fa-circle-check"></i>Keep size under 5MB</li>
<li><i class="fa-solid fa-circle-check"></i>Supported: JPG, PNG, GIF</li>
</ul>

</div>

</div>
</div>

<script>

function previewImage(event){

const file=event.target.files[0];

if(file){

const reader=new FileReader();

reader.onload=function(e){

document
.getElementById("previewImage")
.src=e.target.result;

document
.getElementById("avatarPreview")
.src=e.target.result;

document
.getElementById("previewContainer")
.classList.add("show");

}

reader.readAsDataURL(file);

}

}

</script>

</body>
</html>