<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SocialHub - Upload Profile Picture</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    input[type="file"] {
      color: #1f2937;
    }
    input[type="file"]::file-selector-button {
      background-color: #3b82f6;
      color: #ffffff;
      padding: 10px 20px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-weight: 500;
      transition: background-color 0.3s;
    }
    input[type="file"]::file-selector-button:hover {
      background-color: #2563eb;
    }
    .preview-container {
      display: none;
      margin-top: 20px;
    }
    .preview-container.show {
      display: block;
    }
  </style>
</head>
<body style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); min-height: 100vh;">
  <nav class="border-b sticky top-0 z-50" style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border-color: #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/profile" class="text-3xl font-bold bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent">SocialHub</a>
        <a href="/profile" class="px-5 py-2.5 rounded-lg transition" style="color: #6b7280; border: 1.5px solid #e5e7eb;">
          <i class="fas fa-arrow-left mr-2"></i>Back
        </a>
      </div>
    </div>
  </nav>

  <div class="max-w-2xl mx-auto px-4 py-12">
    <div class="rounded-2xl" style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e5e7eb; box-shadow: 0 20px 60px -10px rgba(0,0,0,0.15); padding: 40px;">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2" style="color: #1f2937;"><i class="fas fa-image mr-2" style="color: #3b82f6;"></i>Update Profile Picture</h2>
        <p style="color: #6b7280;">Choose a new photo to personalize your profile</p>
      </div>
      
      <form action="/upload" method="post" enctype="multipart/form-data" class="space-y-8">
        
        <div class="relative">
          <label class="block text-sm font-semibold mb-4" style="color: #374151;">Choose File</label>
          <div class="border-3 border-dashed rounded-xl p-12 text-center hover:border-opacity-100 transition cursor-pointer" style="border-color: #3b82f6; background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%);">
            <input 
              type="file" 
              name="image" 
              class="w-full cursor-pointer"
              accept="image/*"
              onchange="previewImage(event)"
              required
            >
            <div class="pointer-events-none">
              <i class="fas fa-cloud-upload-alt text-5xl mb-4" style="color: #3b82f6;"></i>
              <p class="font-semibold text-lg" style="color: #374151;">Drag and drop your image here</p>
              <p class="text-sm mt-2" style="color: #6b7280;">or click to browse your device</p>
              <p class="text-xs mt-3" style="color: #9ca3af;"><i class="fas fa-info-circle mr-1"></i>JPG, PNG, or GIF • Max 5MB</p>
            </div>
          </div>
        </div>

        <div id="previewContainer" class="preview-container">
          <label class="block text-sm font-medium mb-3" style="color: #374151;">Preview</label>
          <div class="border-2 rounded-lg overflow-hidden max-w-xs mx-auto" style="border-color: #e5e7eb;">
            <img id="previewImage" class="w-full h-auto" alt="Preview">
          </div>
        </div>


        <div class="flex gap-3 pt-4">
          <button 
            type="submit"
            class="flex-1 py-3 text-white font-semibold rounded-lg hover:shadow-lg transition transform hover:-translate-y-0.5 flex items-center justify-center gap-2"
            style="background: #3b82f6;"
          >
            <i class="fas fa-upload"></i> Upload Photo
          </button>
          <a 
            href="/profile"
            class="px-6 py-3 font-semibold rounded-lg transition"
            style="background: #f3f4f6; color: #6b7280; border: 1px solid #e5e7eb;"
          >
            Cancel
          </a>
        </div>

      </form>

      <div class="mt-10 pt-8" style="border-color: #e5e7eb; border-top: 2px solid #e5e7eb;">
        <h3 class="font-bold mb-4 text-lg flex items-center" style="color: #10b981;">
          <i class="fas fa-check-circle mr-2 text-xl"></i>Guidelines for Best Results
        </h3>
        <ul class="text-sm space-y-3" style="color: #6b7280;">
          <li class="flex gap-3 items-start">
            <i class="fas fa-check mt-1" style="color: #10b981; flex-shrink: 0;"></i>
            <span>Use a clear, friendly photo of yourself with good lighting</span>
          </li>
          <li class="flex gap-3 items-start">
            <i class="fas fa-check mt-1" style="color: #10b981; flex-shrink: 0;"></i>
            <span>Avoid blurry, low-quality, or heavily filtered images</span>
          </li>
          <li class="flex gap-3 items-start">
            <i class="fas fa-check mt-1" style="color: #10b981; flex-shrink: 0;"></i>
            <span>Keep file size under 5MB for faster uploads</span>
          </li>
          <li class="flex gap-3 items-start">
            <i class="fas fa-check mt-1" style="color: #10b981; flex-shrink: 0;"></i>
            <span>Supported formats: JPG, PNG, GIF</span>
          </li>
        </ul>
      </div>
    </div>

  </div>

  <script>
    function previewImage(event) {
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('previewImage').src = e.target.result;
          document.getElementById('previewContainer').classList.add('show');
        }
        reader.readAsDataURL(file);
      }
    }
  </script>
</body>
</html>