<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SocialHub - User Profile</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, system-ui, sans-serif;
      background: radial-gradient(circle at 12% 15%, rgba(56,189,248,0.18), transparent 20%),
                  radial-gradient(circle at 88% 8%, rgba(168,85,247,0.16), transparent 20%),
                  linear-gradient(180deg, #0b1120 0%, #0f172a 55%, #020617 100%);
      color: #e2e8f0;
    }
    .page-shell {
      max-width: 1600px;
      margin: 0 auto;
      padding: 1.5rem 2rem 3rem;
    }
    .navbar {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(20px);
      background: rgba(7, 14, 33, 0.88);
      border-bottom: 1px solid rgba(148,163,184,0.12);
      box-shadow: 0 18px 40px rgba(0,0,0,0.18);
    }
    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.5rem;
    }
    .logo {
      font-size: 1.75rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      color: #ffffff;
      text-decoration: none;
    }
    .nav-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      align-items: center;
    }
    .btn-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      border-radius: 999px;
      padding: 0.95rem 1.4rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;
    }
    .btn-primary {
      background: linear-gradient(135deg, #38bdf8 0%, #3b82f6 100%);
      color: white;
      box-shadow: 0 18px 45px rgba(56,189,248,0.24);
    }
    .btn-secondary {
      border: 1px solid rgba(148,163,184,0.18);
      background: rgba(15,23,42,0.8);
      color: #cbd5e1;
    }
    .btn-pill:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }
    .layout-grid {
      display: grid;
      grid-template-columns: 340px minmax(0, 760px) 280px;
      gap: 28px;
      margin-top: 2rem;
      align-items: start;
    }
    .center-column {
      display: grid;
      gap: 24px;
      width: 100%;
      max-width: 760px;
      margin: 0 auto;
    }
    .left-panel {
      display: grid;
      gap: 24px;
      position: sticky;
      top: 96px;
      align-self: start;
      height: calc(100vh - 120px);
    }
    .right-panel {
      display: grid;
      gap: 24px;
      position: sticky;
      top: 96px;
      align-self: start;
      height: fit-content;
    }
    .panel-title {
      margin: 0 0 1rem;
      font-size: 1.05rem;
      font-weight: 700;
      color: #f8fafc;
    }
    .panel-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.85rem;
      color: #cbd5e1;
    }
    .panel-list li {
      padding: 1rem 1.1rem;
      border-radius: 1.5rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(148,163,184,0.08);
    }
    .profile-panel {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 1.5rem;
      border-radius: 2rem;
      background: rgba(15,23,42,0.94);
      border: 1px solid rgba(255,255,255,0.04);
      box-shadow: 0 40px 90px rgba(0,0,0,0.2);
      backdrop-filter: blur(20px);
      padding: 2.25rem;
      height: 100%;
      overflow-y: auto;
      box-sizing: border-box;
    }
    .profile-header {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      align-items: center;
    }
    .profile-avatar {
      width: 128px;
      height: 128px;
      border-radius: 2rem;
      overflow: hidden;
      border: 4px solid rgba(56,189,248,0.18);
      box-shadow: 0 20px 40px rgba(0,0,0,0.22);
      background: linear-gradient(135deg, rgba(15,23,42,0.95), rgba(15,23,42,0.7));
    }
    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .profile-details {
      display: grid;
      gap: 0.45rem;
      min-width: 0;
    }
    .profile-details h1 {
      margin: 0;
      font-size: clamp(1.75rem, 6vw, 2.75rem);
      font-weight: 900;
      color: #ffffff;
      word-break: break-word;
    }
    .profile-details p {
      margin: 0;
      color: #94a3b8;
      word-break: break-word;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .stat-card {
      border-radius: 1.75rem;
      padding: 1.4rem 0.75rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(148,163,184,0.1);
      text-align: center;
      color: #e2e8f0;
    }
    .stat-card strong {
      display: block;
      font-size: 1.75rem;
      font-weight: 800;
      color: #ffffff;
      white-space: nowrap;
    }
    .stat-card span {
      display: block;
      margin-top: 0.35rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #94a3b8;
      font-size: 0.7rem;
    }
    .post-list {
      display: grid;
      gap: 1.5rem;
      margin-top: 1.5rem;
      width: 100%;
    }
    .post-card {
      border-radius: 2rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 2rem;
      box-shadow: 0 30px 80px rgba(0,0,0,0.18);
      display: grid;
      gap: 1.5rem;
      scroll-margin-top: 120px;
    }
    .post-header {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }
    .comment-stack {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }
    .comment-card {
      border-radius: 1.75rem;
      background: rgba(15,23,42,0.92);
      border: 1px solid rgba(56,189,248,0.2);
      padding: 1.5rem;
      box-shadow: 0 20px 40px rgba(0,0,0,0.18);
      transition: transform 0.2s ease, background 0.2s ease;
    }
    .comment-card:hover {
      transform: translateY(-1px);
      background: rgba(15,23,42,0.98);
    }
    .comment-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      margin-bottom: 0.85rem;
    }
    .comment-header h4 {
      margin: 0;
      font-size: 1rem;
      color: #ffffff;
      font-weight: 800;
    }
    .comment-header p {
      margin: 0;
      color: #94a3b8;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .comment-body {
      margin: 0;
      color: #cbd5e1;
      line-height: 1.8;
      white-space: pre-wrap;
    }
    .comment-meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      background: rgba(56,189,248,0.14);
      color: #bae6fd;
      font-size: 0.78rem;
    }
    .post-header h2 {
      margin: 0;
      font-size: 1.3rem;
      color: #ffffff;
    }
    .post-body {
      color: #d1d5db;
      line-height: 1.8;
    }
    .post-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      color: #94a3b8;
      align-items: center;
      font-size: 0.95rem;
    }
    .post-meta span {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(148,163,184,0.1);
    }
    .post-footer {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .post-footer a,
    .post-footer button {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1rem;
      border-radius: 999px;
      background: rgba(56,189,248,0.12);
      color: #cbd5e1;
      text-decoration: none;
      font-weight: 700;
      border: 1px solid rgba(148,163,184,0.14);
      transition: transform 0.2s ease, background 0.2s ease;
    }
    .post-footer a:hover,
    .post-footer button:hover {
      transform: translateY(-1px);
      background: rgba(56,189,248,0.18);
    }
    .left-panel .post-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    .left-panel .post-footer a {
      width: 100%;
      justify-content: center;
    }
    .left-panel .post-footer span {
      text-align: center;
      font-size: 0.85rem;
      padding: 0.25rem 0;
    }
    .pill-button {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 999px;
      padding: 0.8rem 1rem;
      border: 1px solid rgba(148,163,184,0.14);
      background: rgba(255,255,255,0.06);
      color: #cbd5e1;
      text-decoration: none;
      font-size: 0.9rem;
      transition: transform 0.2s ease, background 0.2s ease;
    }
    .pill-button:hover {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.09);
    }
    .pill-button.active,
    .pill-button.active:hover {
      background: rgba(239,68,68,0.95);
      border-color: rgba(248,113,113,0.4);
      color: #ffffff;
    }
    .pill-button.delete.active,
    .pill-button.delete.active:hover {
      background: rgba(248,113,113,0.95);
      border-color: rgba(248,113,113,0.4);
      color: #ffffff;
    }
    .pill-button.edit.active,
    .pill-button.edit.active:hover {
      background: rgba(59,130,246,0.95);
      border-color: rgba(96,165,250,0.4);
      color: #ffffff;
    }
    .post-image {
      border-radius: 1.75rem;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(0,0,0,0.2);
    }
    .post-image img {
      width: 100%;
      max-height: 420px;
      object-fit: cover;
      display: block;
    }
    @media (max-width: 1180px) {
      .layout-grid {
        grid-template-columns: 1fr;
      }
      .left-panel,
      .right-panel {
        position: static;
        height: auto;
      }
      .profile-panel {
        height: auto;
      }
      .center-column {
        max-width: 100%;
      }
      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }
      .post-list,
      .profile-panel,
      .post-card {
        width: 100%;
      }
      .post-footer,
      .post-meta,
      .comment-header {
        flex-direction: column;
        align-items: stretch;
      }
      .post-footer a,
      .btn-pill,
      .pill-button {
        width: 100%;
        justify-content: center;
      }
    }
    @media (max-width: 768px) {
      .page-shell {
        padding: 1rem;
      }
      .navbar-inner {
        flex-direction: column;
        align-items: stretch;
      }
      .hero {
        gap: 1.25rem;
      }
      .profile-panel,
      .post-card {
        padding: 1.5rem;
      }
      .post-meta span,
      .comment-meta-pill {
        width: 100%;
      }
      .post-image img {
        max-height: 320px;
      }
      .comment-form textarea {
        min-height: 140px;
      }
      .post-header,
      .comment-header {
        gap: 0.75rem;
      }
      .comment-stack {
        gap: 0.85rem;
      }
    }
  </style>
</head>
<body>
  <header class="navbar">
    <div class="navbar-inner">
      <a href="/profile" class="logo">SocialHub</a>
      <div class="nav-actions">
        <a href="/profile/upload" class="btn-pill btn-primary"><i class="fas fa-camera"></i> Upload Photo</a>
        <a href="/logout" class="btn-pill btn-secondary"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
  </header>

  <main class="page-shell">
    <div class="layout-grid">
      <aside class="left-panel">
        <section class="profile-panel">
          <div class="profile-header">
            <div class="profile-avatar">
              <img src="/images/uploads/<%= profileUser.profilepic || 'default.jpg' %>" alt="Profile Picture" onerror="this.onerror=null; this.src='/images/default.jpg';" />
            </div>
            <div class="profile-details">
              <h1><%= profileUser.name %></h1>
              <p>@<%= profileUser.username %></p>
              <p><%= profileUser.email %></p>
              <p><%= profileUser.age %> years old</p>
            </div>
          </div>

          <div class="stats-grid">
            <div class="stat-card">
              <strong><%= profileUser.posts.length %></strong>
              <span>Posts</span>
            </div>
            <div class="stat-card">
              <strong><%= currentUser._id.toString() === profileUser._id.toString() ? 'You' : 'Visitor' %></strong>
              <span>View Mode</span>
            </div>
          </div>

          <div class="post-footer">
            <a href="/profile" class="btn-pill btn-secondary"><i class="fas fa-arrow-left"></i> Back to my feed</a>
            <% if (currentUser._id.toString() !== profileUser._id.toString()) { %>
              <span class="text-slate-400">Viewing someone else's profile</span>
            <% } else { %>
              <span class="text-slate-400">This is your profile</span>
            <% } %>
          </div>
        </section>
      </aside>

      <section class="center-column">
        <section class="post-list">
        <% if (posts.length === 0) { %>
          <section class="post-card text-center">
            <h2 class="text-2xl font-semibold text-white">No posts yet</h2>
            <p class="mt-3 text-slate-400">This user has not shared any posts yet.</p>
          </section>
        <% } else { %>
          <% posts.forEach(function(post) { %>
            <% let liked = post.likes.some(like => like.toString() === currentUser._id.toString()); %>
            <article id="post-<%= post._id %>" class="post-card">
              <div class="post-header">
                <h2><%= post.user ? post.user.name : 'Unknown User' %></h2>
                <div class="post-meta">
                  <span><i class="far fa-calendar-alt"></i><%= new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                  <span><i class="fas fa-heart"></i> <%= post.likes.length %></span>
                </div>
              </div>
              <div class="post-body"><%= post.content %></div>
              <% if (post.image) { %>
                <div class="post-image">
                  <img src="/images/uploads/<%= post.image %>" alt="Post image" onerror="this.onerror=null; this.src='/images/default.jpg';" />
                </div>
              <% } %>
              <div class="post-footer">
                <a href="/like/<%= post._id %>?returnTo=/user/<%= profileUser._id %>&scrollTo=post-<%= post._id %>" class="pill-button <%= liked ? 'active' : '' %>"><i class="<%= liked ? 'fas' : 'far' %> fa-heart"></i><span><%= post.likes.length %></span></a>
              </div>
              <div class="comment-stack">
                <% if (post.comments && post.comments.length > 0) { %>
                  <% post.comments.forEach(function(comment) { %>
                    <div class="comment-card">
                      <div class="comment-header">
                        <div>
                          <h4><%= comment.user ? comment.user.name : 'Unknown' %></h4>
                          <p>@<%= comment.user ? comment.user.username : 'unknown' %></p>
                        </div>
                        <span class="comment-meta-pill"><i class="far fa-calendar-alt"></i> <%= new Date(comment.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                      </div>
                      <p class="comment-body"><%= comment.text %></p>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="comment-card text-center text-slate-400">No comments yet. Be the first to reply.</div>
                <% } %>
              </div>
              <form method="post" action="/comment/<%= post._id %>" class="comment-form">
                <input type="hidden" name="returnTo" value="/user/<%= profileUser._id %>#post-<%= post._id %>">
                <textarea
                  name="text"
                  rows="2"
                  required
                  placeholder="Write a comment..."
                ></textarea>
                <div class="post-footer" style="justify-content:flex-end;">
                  <button type="submit" class="btn-pill btn-primary"><i class="fas fa-comment"></i> Comment</button>
                </div>
              </form>
            </article>
          <% }) %>
        <% } %>
        </section>
      </section>

      <aside class="right-panel">
        <section class="card card-padding">
          <h2 class="panel-title">Recent Activity</h2>
          <ul class="panel-list">
            <li>Liked a premium post</li>
            <li>Commented on feed</li>
            <li>New profile view</li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const scrollTo = new URLSearchParams(window.location.search).get('scrollTo');
      const hash = window.location.hash || (scrollTo ? `#${scrollTo}` : '');
      if (hash) {
        const target = document.querySelector(hash);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  </script>
</body>
</html>