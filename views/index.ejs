<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SocialHub - Sign Up</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    body {
      background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #f8fafc 100%);
      min-height: 100vh;
    }
  </style>
</head>
<body>
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);">
          <i class="fas fa-share-alt text-2xl" style="color: white;"></i>
        </div>
        <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent">SocialHub</h1>
        <p style="color: #6b7280;" class="mt-2 text-sm">Connect. Share. Inspire.</p>
      </div>

      <div class="rounded-2xl" style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e5e7eb; box-shadow: 0 20px 60px -10px rgba(0,0,0,0.15); padding: 40px;">
        <h2 class="text-3xl font-bold mb-8" style="color: #1f2937;">Create Account</h2>
        
        <form action="/register" method="post" class="space-y-5">
          <div>
            <label class="block text-sm font-semibold mb-2.5" style="color: #374151;">Full Name</label>
            <input 
              class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 transition" 
              style="border-color: #e5e7eb; color: #1f2937;"
              type="text" 
              placeholder="John Doe" 
              name="name"
              required
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2.5" style="color: #374151;">Username</label>
            <input 
              class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 transition" 
              style="border-color: #e5e7eb; color: #1f2937;"
              type="text" 
              placeholder="johndoe" 
              name="username"
              required
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2.5" style="color: #374151;">Email Address</label>
            <input 
              class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 transition" 
              style="border-color: #e5e7eb; color: #1f2937;"
              type="email" 
              placeholder="john@example.com" 
              name="email"
              required
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2.5" style="color: #374151;">Age</label>
            <input 
              class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 transition" 
              style="border-color: #e5e7eb; color: #1f2937;"
              type="number" 
              placeholder="18" 
              name="age"
              required
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2.5" style="color: #374151;">Password</label>
            <input 
              class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 transition" 
              style="border-color: #e5e7eb; color: #1f2937;"
              type="password" 
              placeholder="••••••••" 
              name="password"
              required
            >
            <p class="text-xs mt-2" style="color: #9ca3af;"><i class="fas fa-lock mr-1"></i>Minimum 6 characters</p>
          </div>

          <button 
            class="w-full py-3 text-white font-semibold rounded-lg hover:shadow-lg transition transform hover:scale-105"
            style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border: none;"
            type="submit"
          >
            <i class="fas fa-user-plus mr-2"></i>Create Account
          </button>
        </form>

        <div class="mt-8 text-center">
          <p style="color: #6b7280;">Already have an account? 
            <a href="/login" class="font-semibold hover:underline" style="color: #3b82f6;">Sign in</a>
          </p>
        </div>
      </div>

      <!-- Footer -->
      <p class="text-center text-sm mt-8" style="color: #9ca3af;">© 2026 SocialHub. All rights reserved.</p>
    </div>
  </div>
</body>
</html>